{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/generate",
      "destination": "/api/generate.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/generate.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
